---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Gomza - AI-powered Marketing for Real Estate & SaaS." } = Astro.props;
import '../styles/global.css';
import '../styles/mobile.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<meta name="description" content={description}/>
<meta name="keywords" content="marketing agency, real estate marketing, SaaS marketing, performance marketing, SEO, digital growth, Gomza, lead generation, b2b saas" />
<meta name="author" content="Gomza / DigitalEditz" />
<title>{title}</title>

<!-- Canonical URL -->
<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || 'https://gomza.vercel.app').href} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={new URL(Astro.url.pathname, Astro.site || 'https://gomza.vercel.app').href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL('/assets/doberman_face.png', Astro.site || 'https://gomza.vercel.app').href} />
<meta property="og:site_name" content="Gomza" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={new URL(Astro.url.pathname, Astro.site || 'https://gomza.vercel.app').href} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL('/assets/doberman_face.png', Astro.site || 'https://gomza.vercel.app').href} />

<!-- Theme Color -->
<meta name="theme-color" content="#0a1122" />

<link rel="icon" type="image/png" href="/assets/doberman_face.png"/>
<link rel="apple-touch-icon" href="/assets/doberman_face.png"/>
<link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
<link rel="preload" as="script" href="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" />
<link rel="preload" as="script" href="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" />
<link rel="preload" as="script" href="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js" />
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet"/></noscript>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js" is:inline></script>
<script defer src="https://unpkg.com/@studio-freight/lenis@1.0.39/dist/lenis.min.js" is:inline></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js" is:inline></script>

</head>
<body>
<slot />
<script is:inline>
(function(){
  const loader = document.getElementById('page-loader');
  if(!loader) return;
  loader.querySelectorAll('.loader-text span').forEach((span, i) => {
    span.style.animationDelay = (i * 0.08) + 's';
  });
  window.addEventListener('load', function(){
    loader.classList.add('loader-done');
  });
  setTimeout(function(){ loader.classList.add('loader-done'); }, 400);
})();
</script>
<script defer src="/main.min.js?v=2" is:inline></script>
</body>
</html>
