---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Gomza - AI-powered Marketing for Real Estate & SaaS." } = Astro.props;
import '../styles/global.css';
import '../styles/mobile.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<meta name="description" content={description}/>
<meta name="keywords" content="marketing agency, real estate marketing, SaaS marketing, performance marketing, SEO, digital growth, Gomza, lead generation, b2b saas" />
<meta name="author" content="Gomza / DigitalEditz" />
<title>{title}</title>

<!-- Canonical URL -->
<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || 'https://gomza.vercel.app').href} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={new URL(Astro.url.pathname, Astro.site || 'https://gomza.vercel.app').href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL('/assets/doberman_face.png', Astro.site || 'https://gomza.vercel.app').href} />
<meta property="og:site_name" content="Gomza" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={new URL(Astro.url.pathname, Astro.site || 'https://gomza.vercel.app').href} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL('/assets/doberman_face.png', Astro.site || 'https://gomza.vercel.app').href} />

<!-- Theme Color -->
<meta name="theme-color" content="#0a1122" />

<link rel="icon" type="image/png" href="/assets/doberman_face.png"/>
<link rel="apple-touch-icon" href="/assets/doberman_face.png"/>
<link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
<link rel="preload" as="script" href="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" />
<link rel="preload" as="script" href="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" />
<link rel="preload" as="script" href="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js" />
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&display=swap" rel="stylesheet" media="print" onload="this.media='all'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&display=swap" rel="stylesheet"/></noscript>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js"></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"></script>

<script defer>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof VanillaTilt !== 'undefined' && window.innerWidth >= 768) {
      VanillaTilt.init(document.querySelectorAll(".btn-primary, .btn-ghost, .nav-cta, .gen-btn"), {
        max: 15,
        speed: 400,
        scale: 1.05
      });
    }
  });
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://gomza.vercel.app/#organization",
      "name": "Gomza",
      "url": "https://gomza.vercel.app",
      "logo": "https://gomza.vercel.app/assets/doberman_face.png",
      "description": "Innovative marketing agency shaping the future of Real Estate & SaaS.",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@gomza.com",
        "contactType": "customer support"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://gomza.vercel.app/#website",
      "url": "https://gomza.vercel.app",
      "name": "Gomza - AI-powered Marketing for Real Estate & SaaS.",
      "publisher": {
        "@id": "https://gomza.vercel.app/#organization"
      }
    },
    {
      "@type": "WebPage",
      "@id": "https://gomza.vercel.app/#webpage",
      "url": "https://gomza.vercel.app",
      "name": "Gomza | Performance Marketing Agency",
      "isPartOf": {
        "@id": "https://gomza.vercel.app/#website"
      },
      "about": {
        "@id": "https://gomza.vercel.app/#organization"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://gomza.vercel.app/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://gomza.vercel.app"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Services",
          "item": "https://gomza.vercel.app/#services"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Case Studies",
          "item": "https://gomza.vercel.app/#case-studies"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://gomza.vercel.app/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Which marketing channels provide the best ROI for SaaS companies?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For B2B SaaS, the best ROI typically comes from a strategic mix of SEO for long-term organic acquisition, targeted LinkedIn Ads for account-based marketing, and high-intent Google Ads for immediate lead generation. Gomza customizes this channel mix based on your specific CAC (Customer Acquisition Cost) targets."
          }
        },
        {
          "@type": "Question",
          "name": "How can SaaS brands improve Customer Acquisition Cost (CAC) and retention?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Improving CAC involves Conversion Rate Optimization (CRO) to maximize the value of existing traffic and precise audience targeting to eliminate wasted ad spend. For retention, we focus on post-click experiences and lifecycle email marketing to keep users engaged. <a href='https://gomza.vercel.app/#services'>Learn more about our services</a>."
          }
        },
        {
          "@type": "Question",
          "name": "How do Real Estate agencies optimize their online presence to attract local buyers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Local SEO is paramount for Real Estate. We optimize your Google Business Profile, create hyper-local landing pages, and run geotargeted social media and PPC campaigns to ensure you appear when local buyers and sellers are searching for properties."
          }
        },
        {
          "@type": "Question",
          "name": "How much of a Real Estate marketing budget should be allocated to digital vs. traditional?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "While traditional marketing (flyers, signs) is still relevant for local brand awareness, digital marketing should comprise 60-80% of your budget to ensure measurable ROI, targeted lead generation, and scalable growth. Gomza helps balance this distribution for maximum impact."
          }
        }
      ]
    }
  ]
}
</script>
</head>
<body>
<slot />
<script is:inline>
(function(){
  const loader = document.getElementById('page-loader');
  if(!loader) return;
  loader.querySelectorAll('.loader-text span').forEach((span, i) => {
    span.style.animationDelay = (i * 0.08) + 's';
  });
  window.addEventListener('load', function(){
    loader.classList.add('loader-done');
  });
  setTimeout(function(){ loader.classList.add('loader-done'); }, 400);
})();
</script>
<script defer src="/main.min.js?v=4"></script>
<script is:inline>
  /* -- THEME TOGGLE 3-WAY: dark > light > system -- */
  (function(){
    var THEMES = ['dark', 'light', 'system'];
    function getSystemPref() {
      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }
    function applyTheme(theme) {
      var effective = theme === 'system' ? getSystemPref() : theme;
      document.body.classList.toggle('light-mode', effective === 'light');
      document.documentElement.classList.toggle('light-mode', effective === 'light');
    }
    function updateIcon(btn, theme) {
      if (!btn) return;
      btn.querySelectorAll('.theme-icon').forEach(function(el){ el.style.display = 'none'; });
      var map = { dark: 'icon-moon', light: 'icon-sun', system: 'icon-system' };
      var iconEl = btn.querySelector('.' + (map[theme] || 'icon-moon'));
      if (iconEl) iconEl.style.display = 'block';
      var labels = { dark: 'Dark mode', light: 'Light mode', system: 'System default' };
      btn.setAttribute('title', labels[theme] || '');
    }
    var saved;
    try { saved = localStorage.getItem('theme') || 'dark'; } catch(e) { saved = 'dark'; }
    if (THEMES.indexOf(saved) === -1) saved = 'dark';
    applyTheme(saved);
    try {
      window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function() {
        var cur; try { cur = localStorage.getItem('theme'); } catch(e) { cur = 'dark'; }
        if (cur === 'system') applyTheme('system');
      });
    } catch(e) {}
    document.addEventListener('DOMContentLoaded', function() {
      var themeBtn = document.getElementById('theme-toggle');
      if (!themeBtn) return;
      var cur; try { cur = localStorage.getItem('theme') || 'dark'; } catch(e) { cur = 'dark'; }
      if (THEMES.indexOf(cur) === -1) cur = 'dark';
      updateIcon(themeBtn, cur);
      themeBtn.addEventListener('click', function() {
        var idx = THEMES.indexOf(cur);
        cur = THEMES[(idx + 1) % THEMES.length];
        try { localStorage.setItem('theme', cur); } catch(e) {}
        applyTheme(cur);
        updateIcon(themeBtn, cur);
      });
    });
  })();
</script>
</body>
</html>
