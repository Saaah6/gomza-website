---
interface Props {
  platform: string;
  brand: string;
  description?: string;
  objective?: string;
  challenges?: string[];
  strategy?: string[];
  results?: string[];
  services?: string[];
  imageUrl?: string;
}

const { 
  platform, 
  brand, 
  description, 
  objective, 
  challenges, 
  strategy, 
  results, 
  services,
  imageUrl = "/assets/placeholder-dashboard.png" 
} = Astro.props;
---

<div class="case-study-card">
  <div class="case-study-header">
    <h3 class="case-study-title">{brand}</h3>
    <p class="case-study-subtitle">
      <span class="platform">{platform}</span>
    </p>
    {description && (
      <p class="case-study-desc">{description}</p>
    )}
  </div>
  
  {objective && (
    <div class="cs-section">
      <h4>Objective</h4>
      <p>{objective}</p>
    </div>
  )}

  {(challenges || strategy) && (
    <div class="cs-split">
      {challenges && (
        <div class="cs-section">
          <h4>Challenges</h4>
          <ul>
            {challenges.map(c => <li>{c}</li>)}
          </ul>
        </div>
      )}
      {strategy && (
        <div class="cs-section">
          <h4>Strategy</h4>
          <ul>
            {strategy.map(s => <li>{s}</li>)}
          </ul>
        </div>
      )}
    </div>
  )}

  {results && (
    <div class="cs-section results-section">
      <h4>Results</h4>
      <div class="results-grid">
        {results.map(r => (
          <div class="result-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>{r}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  {services && (
    <div class="cs-section">
      <h4>Services</h4>
      <div class="services-tags">
        {services.map(s => <span class="svc-tag">{s}</span>)}
      </div>
    </div>
  )}
  
  <div class="case-study-image-wrapper case-study-trigger" style="cursor: pointer; margin-top: auto;">
    <!-- Mock Browser Bar -->
    <div class="mock-browser-bar">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>
    <!-- Image or Premium Placeholder -->
    <div class="image-placeholder">
      {imageUrl !== "/assets/placeholder-dashboard.png" ? (
        <img src={imageUrl} alt={`${brand} Campaign Performance`} loading="lazy" />
      ) : (
        <div class="premium-dummy-image">
          <div class="abstract-chart">
            <div class="bar" style="height: 40%;"></div>
            <div class="bar" style="height: 70%;"></div>
            <div class="bar" style="height: 50%;"></div>
            <div class="bar" style="height: 90%;"></div>
            <div class="bar" style="height: 60%;"></div>
            <div class="bar" style="height: 85%;"></div>
            <div class="bar" style="height: 100%;"></div>
          </div>
          <div class="dummy-text-overlay">
            <div class="dummy-metric">+340%</div>
            <div class="dummy-label">ROAS</div>
          </div>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .case-study-card {
    background: rgba(15, 20, 35, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    overflow: hidden;
    position: relative;
    backdrop-filter: blur(10px);
  }
  
  .case-study-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(41, 211, 255, 0.15);
    border-color: rgba(41, 211, 255, 0.3);
  }

  .case-study-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .case-study-title {
    font-size: 1.6rem;
    font-weight: 700;
    background: linear-gradient(90deg, #ffffff, #a5b4fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
    letter-spacing: -0.5px;
  }

  .case-study-subtitle {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    line-height: 1.4;
  }
  
  .case-study-desc {
    font-size: 0.9rem;
    color: rgba(251, 253, 255, 0.6);
    margin: 0.5rem 0 0 0;
    line-height: 1.5;
  }
  
  .platform {
    font-weight: 600;
    color: #f4a62a;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 1px;
  }

  .cs-section h4 {
    color: #fff;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 8px 0;
    opacity: 0.8;
  }

  .cs-section p {
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  .cs-section ul {
    margin: 0;
    padding-left: 1.2rem;
    color: rgba(255,255,255,0.7);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .cs-section ul li {
    margin-bottom: 4px;
  }

  .cs-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .results-section {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 16px;
  }

  .results-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .result-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    color: #4ade80;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .result-item svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .services-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .svc-tag {
    background: rgba(41,211,255,0.1);
    color: #8ab4ff;
    border: 1px solid rgba(41,211,255,0.2);
    padding: 4px 10px;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .case-study-image-wrapper {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.15);
    position: relative;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }

  .mock-browser-bar {
    height: 28px;
    background: #1e1e1e;
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 6px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .mock-browser-bar .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #27c93f; }

  .image-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .case-study-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #000;
    transition: transform 0.5s ease;
  }
  
  .case-study-card:hover .case-study-image-wrapper img {
    transform: scale(1.05);
  }

  @media (max-width: 640px) {
    .cs-split {
      grid-template-columns: 1fr;
    }
  }
</style>
