---
import ThreePlane from './ThreePlane.jsx';

interface Props {
  platform: string;
  brand: string;
  description?: string;
  objective?: string;
  challenges?: string[];
  strategy?: string[];
  results?: string[];
  services?: string[];
  imageUrl?: string;
  imageAlt?: string;
}

const { 
  platform, 
  brand, 
  description, 
  objective, 
  challenges, 
  strategy, 
  results, 
  services,
  imageUrl = "/assets/placeholder-dashboard.png",
  imageAlt
} = Astro.props;
---

<div class="case-study-card">
  <!-- ALWAYS VISIBLE HEADER -->
  <div class="csc-visible-header">
    <div class="csc-info">
      <div class="csc-meta">
        <span class="platform">{platform}</span>
      </div>
      <h3 class="case-study-title">{brand}</h3>
      {description && (
        <p class="case-study-desc">{description}</p>
      )}
      {objective && (
        <div class="csc-objective-box">
          <span class="obj-label">Objective:</span>
          <p class="csc-objective">{objective}</p>
        </div>
      )}
      
      <div class="csc-toggle-action">
        <span class="toggle-text view-details-msg">Click to view details</span>
        <span class="toggle-text hide-details-msg">Click to hide details</span>
        <svg class="toggle-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </div>
    </div>

    <div class="case-study-image-wrapper">
      <div class="mock-browser-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <div class="image-placeholder">
        {imageUrl === "/assets/indigo_airlines.png" ? (
          <div style="width: 100%; height: 100%; position: relative; background: #0f172a; overflow: hidden; border-radius: 8px;">
            <ThreePlane client:visible />
          </div>
        ) : imageUrl !== "/assets/placeholder-dashboard.png" ? (
          <img loading="lazy" decoding="async" src={imageUrl} alt={imageAlt || `${brand} Campaign Performance Dashboard`} />
        ) : (
          <div class="premium-dummy-image">
            <div class="abstract-chart">
              <div class="bar" style="height: 40%;"></div>
              <div class="bar" style="height: 70%;"></div>
              <div class="bar" style="height: 50%;"></div>
              <div class="bar" style="height: 90%;"></div>
              <div class="bar" style="height: 60%;"></div>
              <div class="bar" style="height: 85%;"></div>
              <div class="bar" style="height: 100%;"></div>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
  
  <!-- EXPANDABLE CONTENT (CSS Grid height animation) -->
  <div class="csc-expandable-content">
    <div class="csc-inner-wrapper">
      <div class="csc-divider"></div>
      
      {(challenges || strategy) && (
        <div class="cs-split">
          {challenges && (
            <div class="cs-section challenge-block">
              <h4>Challenges</h4>
              <ul>
                {challenges.map(c => <li>{c}</li>)}
              </ul>
            </div>
          )}
          {strategy && (
            <div class="cs-section strategy-block">
              <h4>Strategy</h4>
              <ul>
                {strategy.map(s => <li>{s}</li>)}
              </ul>
            </div>
          )}
        </div>
      )}

      {results && (
        <div class="cs-section results-section">
          <h4>Results</h4>
          <div class="results-grid">
            {results.map(r => (
              <div class="result-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>{r}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {services && (
        <div class="cs-section services-section">
          <h4>Services Delivered</h4>
          <div class="services-tags">
            {services.map(s => <span class="svc-tag">{s}</span>)}
          </div>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .case-study-card {
    background: rgba(10, 15, 30, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 10px 40px rgba(0,0,0,0.25), inset 0 1px 1px rgba(255,255,255,0.05);
    transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease, transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    margin-bottom: 2rem;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    will-change: transform, box-shadow;
  }
  
  .case-study-card:hover {
    background: rgba(16, 22, 42, 0.65);
    border-color: rgba(79, 124, 255, 0.35);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4), 0 0 30px rgba(79, 124, 255, 0.12);
    transform: translateY(-4px);
  }

  .csc-visible-header {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 40px;
    padding: 40px;
    align-items: center;
  }

  .csc-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .csc-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .case-study-title {
    font-size: 2.1rem;
    font-weight: 800;
    font-family: 'Space Grotesk', sans-serif;
    background: linear-gradient(90deg, #ffffff 30%, #cbd5e1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
    letter-spacing: -0.5px;
    line-height: 1.15;
  }
  
  .platform {
    display: inline-block;
    background: rgba(255, 181, 71, 0.08);
    border: 1px solid rgba(255, 181, 71, 0.25);
    color: #ffb547;
    padding: 5px 14px;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-family: 'Space Grotesk', sans-serif;
  }

  .case-study-desc {
    font-size: 1.05rem;
    color: rgba(251, 253, 255, 0.8);
    margin: 0;
    line-height: 1.6;
  }

  .csc-objective-box {
    background: rgba(255, 255, 255, 0.02);
    border-left: 3px solid var(--blue);
    padding: 10px 16px;
    border-radius: 0 8px 8px 0;
  }

  .obj-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--blue-bright);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
  }

  .csc-objective {
    font-size: 0.95rem;
    color: rgba(251, 253, 255, 0.75);
    margin: 0;
    line-height: 1.5;
  }

  /* Toggle hint action */
  .csc-toggle-action {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    color: var(--blue-bright);
    font-weight: 700;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .case-study-card:hover .csc-toggle-action {
    color: #ffffff;
  }

  .toggle-arrow {
    width: 18px;
    height: 18px;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .hide-details-msg {
    display: none;
  }

  /* Image wrappers */
  .case-study-image-wrapper {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    background: #060b18;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 12px 30px rgba(0,0,0,0.4);
    display: flex;
    flex-direction: column;
    transition: transform 0.5s cubic-bezier(0.165, 0.84, 0.44, 1), border-color 0.5s ease;
  }

  .case-study-card:hover .case-study-image-wrapper {
    transform: scale(1.015);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .mock-browser-bar {
    height: 28px;
    background: rgba(15, 23, 42, 0.6);
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 6px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .mock-browser-bar .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #27c93f; }

  .image-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .image-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  .case-study-card:hover .image-placeholder img {
    transform: scale(1.04);
  }

  /* EXPANDABLE AREA LOGIC: CSS Grid Trick */
  .csc-expandable-content {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 0.45s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.35s ease;
  }

  .csc-inner-wrapper {
    overflow: hidden;
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    transition: padding 0.45s ease;
  }

  /* State when expanded */
  .case-study-card.is-expanded .csc-expandable-content {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .case-study-card.is-expanded .csc-inner-wrapper {
    padding: 10px 40px 40px 40px;
  }

  .case-study-card.is-expanded .toggle-arrow {
    transform: rotate(-180deg);
  }

  .case-study-card.is-expanded .view-details-msg {
    display: none;
  }

  .case-study-card.is-expanded .hide-details-msg {
    display: inline;
  }

  .csc-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
    margin-bottom: 8px;
  }

  /* Internal Grid and Details styling */
  .cs-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .cs-section h4 {
    color: rgba(251, 253, 255, 0.95);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0 0 16px 0;
    font-weight: 800;
    font-family: 'Space Grotesk', sans-serif;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .challenge-block h4 {
    color: #ff6b8b;
  }

  .strategy-block h4 {
    color: var(--blue-bright);
  }

  .cs-section ul {
    color: rgba(251, 253, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    padding-left: 1.25rem;
  }

  .cs-section ul li {
    margin-bottom: 8px;
  }

  .results-section {
    background: rgba(74, 222, 128, 0.03);
    border: 1px solid rgba(74, 222, 128, 0.12);
    border-radius: 18px;
    padding: 24px 32px;
  }

  .results-section h4 {
    color: #4ade80;
    margin-bottom: 20px;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  .result-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #ffffff;
    font-size: 1.05rem;
    line-height: 1.4;
  }

  .result-item span {
    font-weight: 500;
  }

  .result-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 3px;
    color: #4ade80;
    filter: drop-shadow(0 0 8px rgba(74, 222, 128, 0.6));
  }

  .services-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .svc-tag {
    background: rgba(41,211,255,0.06);
    color: #8ab4ff;
    border: 1px solid rgba(41,211,255,0.18);
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    font-family: 'Space Grotesk', sans-serif;
  }

  .svc-tag:hover {
    background: rgba(79, 124, 255, 0.18);
    color: #ffffff;
    border-color: rgba(79, 124, 255, 0.4);
  }

  .premium-dummy-image {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0f172a, #050a14);
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .abstract-chart {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    height: 60%;
    width: 70%;
  }

  .abstract-chart .bar {
    flex: 1;
    background: linear-gradient(180deg, var(--blue-bright), var(--blue));
    border-radius: 4px 4px 0 0;
    opacity: 0.7;
    animation: barGrow 1.5s ease-out forwards;
    transform-origin: bottom;
  }

  .abstract-chart .bar:nth-child(even) {
    background: linear-gradient(180deg, var(--gold), #d97706);
  }

  @keyframes barGrow {
    0% { transform: scaleY(0); }
    100% { transform: scaleY(1); }
  }

  /* Responsive styling */
  @media (max-width: 990px) {
    .csc-visible-header {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 32px;
    }
    .case-study-image-wrapper {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .csc-visible-header {
      padding: 24px;
    }
    .csc-inner-wrapper {
      padding: 0 24px;
    }
    .case-study-card.is-expanded .csc-inner-wrapper {
      padding: 10px 24px 24px 24px;
    }
    .case-study-title {
      font-size: 1.7rem;
    }
    .cs-split {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .results-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>

<script>
  function initCaseStudyCards() {
    const cards = document.querySelectorAll('.case-study-card');
    cards.forEach(card => {
      if (card.dataset.initialized) return;
      card.dataset.initialized = 'true';
      
      card.addEventListener('click', (e) => {
        // Stop toggle action if user clicked an interactive tag/link inside the card
        if (e.target.closest('a, button, select, input, .svc-tag')) {
          return;
        }
        card.classList.toggle('is-expanded');
      });
    });
  }

  // Initialize immediately
  initCaseStudyCards();

  // Handle page transitions if applicable
  document.addEventListener('astro:page-load', initCaseStudyCards);
</script>
