---
interface Props {
  platform: string;
  brand: string;
  imageUrl?: string;
}

const { platform, brand, imageUrl = "/assets/placeholder-dashboard.png" } = Astro.props;
---

<div class="case-study-card">
  <div class="case-study-header">
    <h3 class="case-study-title">Campaign Performance</h3>
    <p class="case-study-subtitle">
      <span class="platform">{platform}</span> - <span class="brand">{brand}</span>
    </p>
  </div>
  
  <div class="case-study-image-wrapper">
    <!-- Image or Premium Placeholder -->
    <div class="image-placeholder">
      {imageUrl !== "/assets/placeholder-dashboard.png" ? (
        <img src={imageUrl} alt={`${brand} Campaign Performance`} loading="lazy" />
      ) : (
        <div class="premium-dummy-image">
          <div class="abstract-chart">
            <div class="bar" style="height: 40%;"></div>
            <div class="bar" style="height: 70%;"></div>
            <div class="bar" style="height: 50%;"></div>
            <div class="bar" style="height: 90%;"></div>
            <div class="bar" style="height: 60%;"></div>
            <div class="bar" style="height: 85%;"></div>
            <div class="bar" style="height: 100%;"></div>
          </div>
          <div class="dummy-text-overlay">
            <div class="dummy-metric">+340%</div>
            <div class="dummy-label">ROAS</div>
          </div>
        </div>
      )}
    </div>
  </div>

  <div class="case-study-footer">
    <p>We do it all, We measure everything.</p>
  </div>
</div>

<style>
  .case-study-card {
    background: rgba(15, 20, 35, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    overflow: hidden;
    position: relative;
    backdrop-filter: blur(10px);
  }
  
  .case-study-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(41, 211, 255, 0.15);
    border-color: rgba(41, 211, 255, 0.3);
  }

  .case-study-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .case-study-title {
    font-size: 1.6rem;
    font-weight: 700;
    background: linear-gradient(90deg, #ffffff, #a5b4fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
    letter-spacing: -0.5px;
  }

  .case-study-subtitle {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    line-height: 1.4;
  }
  
  .platform {
    font-weight: 600;
    color: #f4a62a;
  }

  .brand {
    font-weight: 500;
  }

  .case-study-image-wrapper {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 12px;
    overflow: hidden;
    background: #0a0f1e;
    border: 1px solid rgba(255, 255, 255, 0.06);
    position: relative;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
  }

  .case-study-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .case-study-card:hover .case-study-image-wrapper img {
    transform: scale(1.05);
  }

  /* Premium Dummy UI */
  .premium-dummy-image {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1e1b4b 0%, #0f172a 100%);
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
    overflow: hidden;
  }
  
  .premium-dummy-image::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(41,211,255,0.1) 0%, transparent 60%);
    opacity: 0.5;
  }

  .abstract-chart {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    width: 80%;
    height: 60%;
    position: relative;
    z-index: 2;
  }

  .bar {
    flex: 1;
    background: linear-gradient(180deg, rgba(41,211,255,0.8) 0%, rgba(41,211,255,0) 100%);
    border-radius: 4px 4px 0 0;
    box-shadow: 0 -4px 12px rgba(41,211,255,0.2);
    animation: growBar 1.5s ease-out forwards;
    transform-origin: bottom;
  }

  @keyframes growBar {
    0% { transform: scaleY(0); opacity: 0; }
    100% { transform: scaleY(1); opacity: 1; }
  }

  .dummy-text-overlay {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .dummy-metric {
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
    text-shadow: 0 4px 12px rgba(0,0,0,0.5);
  }

  .dummy-label {
    font-size: 0.9rem;
    color: #4ade80;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .case-study-footer {
    text-align: center;
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .case-study-footer p {
    font-size: 1.05rem;
    font-weight: 500;
    color: rgba(255,255,255,0.6);
    margin: 0;
    font-style: italic;
  }
</style>
