---
import ThreePlane from './ThreePlane.jsx';

interface Props {
  platform: string;
  brand: string;
  description?: string;
  objective?: string;
  challenges?: string[];
  strategy?: string[];
  results?: string[];
  services?: string[];
  imageUrl?: string;
  imageAlt?: string;
}

const { 
  platform, 
  brand, 
  description, 
  objective, 
  challenges, 
  strategy, 
  results, 
  services,
  imageUrl = "/assets/placeholder-dashboard.png",
  imageAlt
} = Astro.props;
---

<div class="case-study-card">
  <!-- ALWAYS VISIBLE HEADER -->
  <div class="csc-visible-header">
    <div class="csc-info">
      <h3 class="case-study-title">{brand}</h3>
      <p class="case-study-subtitle">
        <span class="platform">{platform}</span>
      </p>
      {description && (
        <p class="case-study-desc">{description}</p>
      )}
      {objective && (
        <p class="csc-objective">{objective}</p>
      )}
      <div class="csc-desktop-hint"><span class="blink-text">Click to view details &rarr;</span></div>
    </div>

    <div class="case-study-image-wrapper">
      <div class="mock-browser-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <div class="image-placeholder">
        {imageUrl === "/assets/indigo_airlines.png" ? (
          <div style="width: 100%; height: 100%; position: relative; background: #0f172a; overflow: hidden; border-radius: 8px;">
            <ThreePlane client:visible />
          </div>
        ) : imageUrl !== "/assets/placeholder-dashboard.png" ? (
          <img loading="lazy" decoding="async" src={imageUrl} alt={imageAlt || `${brand} Campaign Performance Dashboard`} />
        ) : (
          <div class="premium-dummy-image">
            <div class="abstract-chart">
              <div class="bar" style="height: 40%;"></div>
              <div class="bar" style="height: 70%;"></div>
              <div class="bar" style="height: 50%;"></div>
              <div class="bar" style="height: 90%;"></div>
              <div class="bar" style="height: 60%;"></div>
              <div class="bar" style="height: 85%;"></div>
              <div class="bar" style="height: 100%;"></div>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
  
  <!-- EXPANDABLE CONTENT -->
  <div class="csc-expandable-content">
    <div class="csc-inner-wrapper">
      <div class="csc-divider"></div>
      
      {(challenges || strategy) && (
        <div class="cs-split">
          {challenges && (
            <div class="cs-section">
              <h4>Challenges</h4>
              <ul>
                {challenges.map(c => <li>{c}</li>)}
              </ul>
            </div>
          )}
          {strategy && (
            <div class="cs-section">
              <h4>Strategy</h4>
              <ul>
                {strategy.map(s => <li>{s}</li>)}
              </ul>
            </div>
          )}
        </div>
      )}

      {results && (
        <div class="cs-section results-section">
          <h4>Results</h4>
          <div class="results-grid">
            {results.map(r => (
              <div class="result-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                <span>{r}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {services && (
        <div class="cs-section services-section">
          <h4>Services</h4>
          <div class="services-tags">
            {services.map(s => <span class="svc-tag">{s}</span>)}
          </div>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .case-study-card {
    background: rgba(15, 20, 35, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 10px 40px rgba(0,0,0,0.2), inset 0 1px 1px rgba(255,255,255,0.05);
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    margin-bottom: 2rem;
  }
  
  .case-study-card:hover {
    background: rgba(20, 25, 45, 0.65);
    border-color: rgba(41, 211, 255, 0.25);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(41, 211, 255, 0.08);
    transform: translateY(-4px);
  }

  .csc-visible-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    padding: 36px;
    align-items: center;
  }

  .csc-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .case-study-title {
    font-size: 2rem;
    font-weight: 700;
    background: linear-gradient(90deg, #ffffff, #a5b4fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
    letter-spacing: -0.5px;
    line-height: 1.1;
  }

  .case-study-subtitle {
    margin: 0;
  }
  
  .platform {
    display: inline-block;
    background: rgba(244, 166, 42, 0.1);
    border: 1px solid rgba(244, 166, 42, 0.3);
    color: #f4a62a;
    padding: 4px 12px;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .case-study-desc, .csc-objective {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    line-height: 1.6;
  }

  .csc-desktop-hint {
    margin-top: 12px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #3b82f6;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .case-study-card.is-expanded .csc-desktop-hint,
  .case-study-card:hover .csc-desktop-hint {
    opacity: 0;
  }

  .case-study-image-wrapper {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 12px 30px rgba(0,0,0,0.3);
    display: flex;
    flex-direction: column;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.6s ease;
  }

  .case-study-card:hover .case-study-image-wrapper {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 20px 50px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.2);
  }

  .mock-browser-bar {
    height: 28px;
    background: #1e1e1e;
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 6px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .mock-browser-bar .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #27c93f; }

  .image-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .image-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Expandable Area Logic */
  .csc-expandable-content {
    max-height: 0px;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.6s ease-in-out, opacity 0.5s ease-in-out;
  }

  .csc-inner-wrapper {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 0 36px 0 36px;
    transition: padding 0.6s ease-in-out;
  }

  .case-study-card.is-expanded .csc-expandable-content,
  .case-study-card:hover .csc-expandable-content {
    max-height: 2000px;
    opacity: 1;
  }

  .case-study-card.is-expanded .csc-inner-wrapper,
  .case-study-card:hover .csc-inner-wrapper {
    padding: 0 36px 36px 36px;
  }

  .csc-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    margin-bottom: 12px;
  }

  /* Internal Sections */
  .cs-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .cs-section h4 {
    color: #a5b4fc;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0 0 12px 0;
    font-weight: 700;
  }

  .cs-section p, .cs-section ul {
    color: rgba(255,255,255,0.75);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .cs-section ul {
    padding-left: 1.2rem;
  }

  .cs-section ul li {
    margin-bottom: 8px;
  }

  .results-section {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 24px;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }

  .result-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #4ade80;
    font-size: 1.1rem;
    font-weight: 700;
    text-shadow: 0 0 20px rgba(74, 222, 128, 0.3);
  }

  .result-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .services-section {
    margin-top: 8px;
  }

  .services-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .svc-tag {
    background: rgba(41,211,255,0.05);
    color: #60a5fa;
    border: 1px solid rgba(41,211,255,0.15);
    padding: 6px 14px;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .svc-tag:hover {
    background: rgba(41,211,255,0.15);
    color: #fff;
    border-color: rgba(41,211,255,0.4);
  }

  /* Light mode is handled in global.css, but we can add specific resets if needed */

  @media (max-width: 900px) {
    .csc-visible-header {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .case-study-image-wrapper {
      order: -1; /* image on top for mobile */
    }
  }

  @media (max-width: 768px) {
    /* Auto expand on mobile */
    .csc-expandable-content {
      grid-template-rows: 1fr;
      opacity: 1;
      padding: 0 24px 24px 24px;
    }
    .csc-visible-header {
      padding: 24px;
    }
    .csc-desktop-hint {
      display: none;
    }
    .cs-split {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .results-grid {
      grid-template-columns: 1fr;
    }
  }

  .blink-text {
    animation: blinker 2s linear infinite;
  }
  @keyframes blinker {
    50% { opacity: 0.3; }
  }
  .case-study-card {
    cursor: pointer;
  }
</style>


<script>
  // Add click to expand functionality and close on mouse leave
  const cards = document.querySelectorAll('.case-study-card');
  cards.forEach(card => {
    card.addEventListener('click', () => {
      card.classList.toggle('is-expanded');
    });
    card.addEventListener('mouseleave', () => {
      card.classList.remove('is-expanded');
    });
  });
</script>
