                     <div style="width: 100%; height: 100%; background: #000; border-radius: 50%; border: 1px solid #fff;"></div>
                   </div>
                   <div style="color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; font-weight: 600; text-shadow: 0 1px 3px rgba(0,0,0,0.8);">gomza_realty <span style="font-weight: 400; opacity: 0.8; font-size: 11px; margin-left: 4px;">Sponsored</span></div>
                 </div>
                 <svg width="24" height="24" viewBox="0 0 24 24" fill="white" style="filter: drop-shadow(0 1px 2px rgba(0,0,0,0.5));"><path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
               </div>
               
               <div style="text-align: center; background: rgba(0,0,0,0.6); backdrop-filter: blur(10px); padding: 16px; border-radius: 12px; margin-bottom: 20px;">
                  <h3 style="color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 20px; margin: 0 0 8px 0; font-weight: 700;">${slide.title}</h3>
                  <p style="color: rgba(255,255,255,0.9); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; margin: 0; line-height: 1.4;">${slide.desc}</p>
               </div>
               
               <div style="display: flex; flex-direction: column; align-items: center; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; text-shadow: 0 1px 4px rgba(0,0,0,0.8);">
                 <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" style="margin-bottom: 4px; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.5));"><path d="M18 15l-6-6-6 6"/></svg>
                 ${slide.btn}
               </div>
            </div>
           `;
        }
        else {
          // Default Social Media / Visual style
          newHTML = `
            <span class="estate-badge" id="billboard-badge">${slide.badge}</span>
            <h3 class="estate-title" id="billboard-title">${slide.title}</h3>
            <p class="estate-desc" id="billboard-desc">${slide.desc}</p>
            <div class="estate-price" id="billboard-price">${slide.price}</div>
            <button class="estate-btn" id="billboard-btn">${slide.btn}</button>
          `;
        }
        
        contentWrapper.innerHTML = newHTML;
        
        // Update background inline (accounting for dark mode overlay)
        if (isLampDark) {
          billboardInner.style.backgroundImage = `linear-gradient(135deg, rgba(5,8,15,0.95), rgba(0,0,0,0.98)), url('${slide.bg}')`;
        } else {
          billboardInner.style.backgroundImage = `linear-gradient(135deg, rgba(5,8,15,0.7), rgba(0,0,0,0.85)), url('${slide.bg}')`;
        }

        // Fade in
        contentWrapper.style.opacity = '1';
        
        currentSlide = (currentSlide + 1) % slides.length;
      }, 500); // Wait for fade out
    }

    // Hook into lamp toggle to instantly update background overlay so it doesn't wait for next slide
    if (lampToggle && billboardInner) {
      lampToggle.addEventListener('click', () => {
         // Re-apply the current slide's background with the new lighting overlay immediately
         const slideIndex = currentSlide === 0 ? slides.length - 1 : currentSlide - 1;
         const slide = slides[slideIndex];
         if (isLampDark) {
          billboardInner.style.backgroundImage = `linear-gradient(135deg, rgba(5,8,15,0.95), rgba(0,0,0,0.98)), url('${slide.bg}')`;
        } else {
          billboardInner.style.backgroundImage = `linear-gradient(135deg, rgba(5,8,15,0.7), rgba(0,0,0,0.85)), url('${slide.bg}')`;
        }
      });
    }

    // Start carousel
    setInterval(updateSlide, 5000);
    // Initialize first advance
    setTimeout(updateSlide, 5000);
  });
</script>

