    <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="rgba(10,15,30,0.95)"/>
  </svg>
</div>

<!-- PROCESS -->
<div id="process" style="background:var(--bg); padding-top: 5rem; padding-bottom: 2rem;">
  <div class="section">
    <div class="label reveal">How We Work</div>
    <h2 class="stitle reveal" style="display: flex; align-items: center; gap: 1rem; margin: 0;">
      Client Onboarding
      <img loading="lazy" decoding="async" src="/assets/professional_human_icon.png" alt="Professional Expert" style="width: 64px; height: 64px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(41,211,255,0.4); box-shadow: 0 0 20px rgba(41,211,255,0.2);" />
    </h2>
    
    <div class="process-timeline reveal" style="margin-top: 3rem; position: relative; padding-left: 2rem;">
      <!-- Vertical line -->
      <div style="position: absolute; left: 6px; top: 10px; bottom: 20px; width: 2px; background: linear-gradient(to bottom, rgba(41,211,255,0.6), rgba(255,181,71,0.6)); border-radius: 2px;"></div>
      
      <div class="process-step" style="position: relative; margin-bottom: 2.5rem;">
        <div style="position: absolute; left: -2rem; top: 4px; width: 14px; height: 14px; background: #0f172a; border: 2px solid #29d3ff; border-radius: 50%; z-index: 2; box-shadow: 0 0 10px rgba(41,211,255,0.5);"></div>
        <h3 style="color: #fff; font-size: 1.3rem; margin: 0 0 0.5rem 0;">1. Book a strategy call</h3>
        <p style="color: rgba(255,255,255,0.7); margin: 0; font-size: 0.95rem; line-height: 1.5;">Schedule a free consultation to discuss your vision and see if we're a good fit.</p>
      </div>

      <div class="process-step" style="position: relative; margin-bottom: 2.5rem;">
        <div style="position: absolute; left: -2rem; top: 4px; width: 14px; height: 14px; background: #0f172a; border: 2px solid #29d3ff; border-radius: 50%; z-index: 2; box-shadow: 0 0 10px rgba(41,211,255,0.5);"></div>
        <h3 style="color: #fff; font-size: 1.3rem; margin: 0 0 0.5rem 0;">2. Understand your needs</h3>
        <p style="color: rgba(255,255,255,0.7); margin: 0; font-size: 0.95rem; line-height: 1.5;">We dive deep to understand your specific needs, wants, and long-term business goals.</p>
      </div>

      <div class="process-step" style="position: relative; margin-bottom: 2.5rem;">
        <div style="position: absolute; left: -2rem; top: 4px; width: 14px; height: 14px; background: #0f172a; border: 2px solid #29d3ff; border-radius: 50%; z-index: 2; box-shadow: 0 0 10px rgba(41,211,255,0.5);"></div>
        <h3 style="color: #fff; font-size: 1.3rem; margin: 0 0 0.5rem 0;">3. Propose a solution</h3>
        <p style="color: rgba(255,255,255,0.7); margin: 0; font-size: 0.95rem; line-height: 1.5;">We present a custom, data-backed strategy designed specifically to achieve your objectives.</p>
      </div>

      <div class="process-step" style="position: relative; margin-bottom: 2.5rem;">
        <div style="position: absolute; left: -2rem; top: 4px; width: 14px; height: 14px; background: #0f172a; border: 2px solid #ffb547; border-radius: 50%; z-index: 2; box-shadow: 0 0 10px rgba(255,181,71,0.5);"></div>
        <h3 style="color: #fff; font-size: 1.3rem; margin: 0 0 0.5rem 0;">4. Build your brand engine</h3>
        <p style="color: rgba(255,255,255,0.7); margin: 0; font-size: 0.95rem; line-height: 1.5;">We execute the plan—managing your website (if needed), building marketing & lead funnels, launching paid ads, and driving SEO/content generation. Everything is tracked, reported, and optimized for maximum growth.</p>
      </div>

      <div class="process-step" style="position: relative;">
