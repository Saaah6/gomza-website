        <a href="#services" style="color: rgba(251,253,255,0.7); text-decoration: none; font-size: 0.85rem; transition: color 0.2s;">Services</a>
        <a href="#niches" style="color: rgba(251,253,255,0.7); text-decoration: none; font-size: 0.85rem; transition: color 0.2s;">Industries</a>
        <a href="/tool" style="color: rgba(251,253,255,0.7); text-decoration: none; font-size: 0.85rem; transition: color 0.2s;">CRO Tool</a>
      </div>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <a href="#" style="color: rgba(251,253,255,0.7); text-decoration: none; font-size: 0.85rem; transition: color 0.2s;">LinkedIn</a>
        <a href="#" style="color: rgba(251,253,255,0.7); text-decoration: none; font-size: 0.85rem; transition: color 0.2s;">Twitter</a>
