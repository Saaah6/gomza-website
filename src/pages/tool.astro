    <span class="hover-letter text-white">G</span><span class="hover-letter text-white">O</span><span class="hover-letter text-white">M</span><span class="hover-letter text-gold">Z</span><span class="hover-letter text-gold">A</span>
  </div>
</footer>

<!-- WHATSAPP FLOAT -->
<a href="https://wa.me/916005643394"
   class="whatsapp-float"
   target="_blank"
   rel="noopener"
   aria-label="Chat on WhatsApp">
